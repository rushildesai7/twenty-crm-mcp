{
  "name": "twenty-crm-mcp",
  "version": "1.1.0",
  "description": "A Model Context Protocol (MCP) server for Twenty CRM integration. Supports stdio, HTTP, and Cloudflare Workers deployment.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "dev": "npx tsx --watch serve.ts",
    "serve": "node dist/serve.js",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "twenty",
    "crm",
    "server",
    "claude",
    "ai",
    "assistant",
    "api",
    "integration"
  ],
  "license": "MIT"
}
